{
  "version": 6,

"configurePresets": [
{
  "name": "default",
  "generator": "Ninja",
  "binaryDir": "build",
  "installDir": "${fileDir}/build/local",
  "cacheVariables": {
    "CMAKE_BUILD_TYPE": "Release",
    "ffilesystem_warning_as_error": true,
    "ffilesystem_fallback": false,
    "CMAKE_MESSAGE_LOG_LEVEL": "VERBOSE",
    "ffilesystem_BUILD_TESTING": true
  }
},
{"name": "build", "inherits": "default",
  "cacheVariables": {
    "ffilesystem_BUILD_TESTING": false
  }
},
{ "name": "debug", "inherits": "default",
  "cacheVariables": {
    "CMAKE_BUILD_TYPE": "Debug"
  }
},
{ "name": "msvc", "inherits": "default",
  "binaryDir": "build-${presetName}",
  "generator": "Visual Studio 18 2026",
  "cacheVariables": {
    "ffilesystem_fortran": false
  }
},
{ "name": "android", "inherits": "default",
  "toolchainFile": "${sourceDir}/android.cmake",
  "binaryDir": "build-${presetName}",
  "cacheVariables": {
    "ffilesystem_fortran": false,
    "ffilesystem_BUILD_TESTING": false
  }
},
{ "name": "android-tests", "inherits": "android",
  "displayName": "Android NDK with tests",
  "description": "Cross-compile for Android and register tests via gtest_add_tests (no host execution). Set CROSSCOMPILING_EMULATOR_AVAILABLE=ON separately to enable gtest_discover_tests with a runner.",
  "cacheVariables": {
    "ffilesystem_BUILD_TESTING": true,
    "CMAKE_CROSSCOMPILING_EMULATOR": "${sourceDir}/test/adb_run.sh"
  }
},
{ "name": "cosmo", "inherits": "default",
  "toolchainFile": "${sourceDir}/cosmopolitan.cmake",
  "binaryDir": "build-${presetName}",
  "cacheVariables": {
    "ffilesystem_fortran": false,
    "ffilesystem_BUILD_TESTING": false
  }
},
{ "name": "ios", "inherits": "default",
  "toolchainFile": "${sourceDir}/ios.cmake",
  "binaryDir": "build-${presetName}",
  "cacheVariables": {
    "ffilesystem_fortran": false,
    "ffilesystem_extra": false,
    "ffilesystem_BUILD_TESTING": false,
    "CMAKE_OSX_SYSROOT": "iphoneos",
    "CMAKE_OSX_ARCHITECTURES": "arm64"
  }
},
{ "name": "ios-sim", "inherits": "ios",
  "cacheVariables": {
    "CMAKE_OSX_SYSROOT": "iphonesimulator"
  }
},
{
  "name": "shared", "inherits": "default",
  "binaryDir": "build-shared",
  "installDir": "${fileDir}/build-shared/local",
  "displayName": "Shared Library",
  "description": "Build shared library instead of static.",
  "cacheVariables": {
    "BUILD_SHARED_LIBS": true,
    "ffilesystem_ENABLE_RPATH": true
  }
},
{
  "name": "coverage",
  "binaryDir": "build-coverage",
  "displayName": "Code Coverage",
  "description": "Build with code coverage enabled.",
  "cacheVariables": {
    "CMAKE_BUILD_TYPE": "Debug",
    "ffilesystem_coverage": true,
    "ffilesystem_fallback": false
  }
},
{
  "name": "tidy", "inherits": "default",
  "displayName": "Clang-Tidy",
  "description": "Build with clang-tidy enabled.",
  "cacheVariables": {
    "CMAKE_BUILD_TYPE": "Debug",
    "ffilesystem_tidy": true
  }
}
],
"buildPresets": [
  { "name": "default", "configurePreset": "default" },
  { "name": "build", "configurePreset": "build", "inherits": "default" },
  { "name": "shared", "configurePreset": "shared", "inherits": "default" },
  { "name": "android", "configurePreset": "android", "inherits": "default" },
  { "name": "android-tests", "configurePreset": "android-tests", "inherits": "default" },
  { "name": "cosmo", "configurePreset": "cosmo", "inherits": "default" },
  { "name": "ios", "configurePreset": "ios", "inherits": "default" },
  { "name": "ios-sim", "configurePreset": "ios-sim", "inherits": "default" },
  { "name": "msvc", "configurePreset": "msvc", "configuration": "Release", "inherits": "default" },
  {
    "name": "explain",
    "configurePreset": "default",
    "nativeToolOptions": ["-d", "explain"]
  },
  {
    "name": "keep",
    "configurePreset": "default",
    "nativeToolOptions": ["-d", "keeprsp", "-d", "keepdepfile"]
  },
  {
    "name": "stats",
    "configurePreset": "default",
    "nativeToolOptions": ["-d", "stats"]
  },
  {
    "name": "debug", "inherits": "default",
    "configurePreset": "debug",
    "configuration": "Debug"
  },
  {
    "name": "tidy",
    "configurePreset": "tidy"
  },
  {
    "name": "coverage",
    "configurePreset": "coverage"
  },
  {
    "name": "run-coverage",
    "configurePreset": "coverage",
    "targets": "coverage"
  }
],
"testPresets": [
{
  "name": "default",
  "configurePreset": "default",
  "configuration": "Release",
  "output": {
    "outputOnFailure": true,
    "verbosity": "verbose"
  },
  "execution": {
    "noTestsAction": "error",
    "scheduleRandom": true,
    "stopOnFailure": false,
    "jobs": 8,
    "$comment": "don't put 0 or ulimit too many open files failures result"
  }
},
{ "name": "shared", "configurePreset": "shared", "inherits": "default" },
{ "name": "android-tests", "configurePreset": "android-tests", "inherits": "default",
  "execution": {
    "jobs": 1,
    "$comment": "adb push clashes with multiple tests using same executable"
  }
},
{ "name": "msvc", "configurePreset": "msvc", "inherits": "default" },
{
  "name": "debug", "inherits": "default",
  "configurePreset": "debug",
  "configuration": "Debug"
}
],
"workflowPresets": [
  {
    "name": "default",
    "steps": [
      { "type": "configure", "name": "default" },
      { "type": "build", "name": "default" },
      { "type": "test", "name": "default" }
    ]
  },
  {
    "name": "build",
    "steps": [
      { "type": "configure", "name": "build" },
      { "type": "build", "name": "build" }
    ]
  },
  {
    "name": "shared",
    "steps": [
      { "type": "configure", "name": "shared" },
      { "type": "build", "name": "shared" },
      { "type": "test", "name": "shared" }
    ]
  },
  {
    "name": "debug",
    "steps": [
      { "type": "configure", "name": "debug" },
      { "type": "build", "name": "debug" },
      { "type": "test", "name": "debug"}
    ]
  },
  { "name": "android",
    "steps": [
      { "type": "configure", "name": "android" },
      { "type": "build", "name": "android" }
    ]
  },
  { "name": "android-tests",
    "steps": [
      { "type": "configure", "name": "android-tests" },
      { "type": "build", "name": "android-tests" },
      { "type": "test", "name": "android-tests" }
    ]
  },
  { "name": "cosmo",
    "steps": [
      { "type": "configure", "name": "cosmo" },
      { "type": "build", "name": "cosmo" }
    ]
  },
  { "name": "ios",
    "steps": [
      { "type": "configure", "name": "ios" },
      { "type": "build", "name": "ios" }
    ]
  },
  { "name": "ios-sim",
    "steps": [
      { "type": "configure", "name": "ios-sim" },
      { "type": "build", "name": "ios-sim" }
    ]
  },
  {
    "name": "msvc",
    "steps": [
      { "type": "configure", "name": "msvc" },
      { "type": "build", "name": "msvc" },
      { "type": "test", "name": "msvc" }
    ]
  },
  {
    "name": "tidy",
    "steps": [
      { "type": "configure", "name": "tidy" },
      { "type": "build", "name": "tidy" }
    ]
  }
]
}
