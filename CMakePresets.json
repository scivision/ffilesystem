    "name": "cpp17",
    "displayName": "Build and test with C++17 standard",
    "steps": [
      { "type": "configure", "name": "cpp17" },
      { "type": "build", "name": "cpp17" },
      { "type": "test", "name": "cpp17" }
    ]
  },
  {
    "name": "cpp23",
    "displayName": "Build and test with C++23 standard",
    "steps": [
      { "type": "configure", "name": "cpp23" },
      { "type": "build", "name": "cpp23" },
      { "type": "test", "name": "cpp23" }
    ]
  },
  {
    "name": "cpp26",
    "displayName": "Build and test with C++26 standard",
    "steps": [
      { "type": "configure", "name": "cpp26" },
      { "type": "build", "name": "cpp26" },
      { "type": "test", "name": "cpp26" }
    ]
  },
  {
    "name": "shared",
    "displayName": "Build & test with shared library",
    "steps": [
      { "type": "configure", "name": "shared" },
      { "type": "build", "name": "shared" },
      { "type": "test", "name": "shared" }
    ]
  },
  {
    "name": "shared-build",
    "displayName": "Build with shared library",
    "steps": [
      { "type": "configure", "name": "shared-build" },
      { "type": "build", "name": "shared-build" }
    ]
  },
  {
    "name": "shared-nofortran",
    "displayName": "Build & test with shared library without Fortran",
    "steps": [
      { "type": "configure", "name": "shared-nofortran" },
      { "type": "build", "name": "shared-nofortran" },
      { "type": "test", "name": "shared-nofortran" }
    ]
  },
  {
    "name": "shared-nofortran-build",
    "displayName": "Build with shared library without Fortran",
    "steps": [
      { "type": "configure", "name": "shared-nofortran-build" },
      { "type": "build", "name": "shared-nofortran-build" }
    ]
  },
  {
    "name": "debug",
    "steps": [
      { "type": "configure", "name": "debug" },
      { "type": "build", "name": "debug" },
      { "type": "test", "name": "debug"}
    ]
  },
  { "name": "android",
    "steps": [
      { "type": "configure", "name": "android" },
      { "type": "build", "name": "android" }
    ]
  },
  { "name": "android-tests",
    "steps": [
      { "type": "configure", "name": "android-tests" },
      { "type": "build", "name": "android-tests" },
      { "type": "test", "name": "android-tests" }
    ]
  },
  { "name": "cosmo",
    "steps": [
      { "type": "configure", "name": "cosmo" },
      { "type": "build", "name": "cosmo" }
    ]
  },
  { "name": "ios",
    "steps": [
      { "type": "configure", "name": "ios" },
      { "type": "build", "name": "ios" }
    ]
  },
  { "name": "ios-sim",
    "steps": [
      { "type": "configure", "name": "ios-sim" },
      { "type": "build", "name": "ios-sim" }
    ]
  },
  { "name": "msvc",
    "steps": [
      { "type": "configure", "name": "msvc" },
      { "type": "build", "name": "msvc" },
      { "type": "test", "name": "msvc" }
    ]},
  { "name": "msvc-nostdfs",
    "steps": [
      { "type": "configure", "name": "msvc-nostdfs" },
