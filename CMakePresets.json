{
  "version": 6,

"configurePresets": [
{
  "name": "default",
  "generator": "Ninja",
  "binaryDir": "build",
  "displayName": "Build and test with C++20 standard",
  "installDir": "${fileDir}/build/local",
  "cacheVariables": {
    "CMAKE_BUILD_TYPE": "Release",
    "ffilesystem_warning_as_error": true,
    "ffilesystem_cpp": true,
    "ffilesystem_fallback": false,
    "CMAKE_MESSAGE_LOG_LEVEL": "VERBOSE",
    "ffilesystem_BUILD_TESTING": true,
    "CMAKE_CXX_STANDARD": "20",
    "CMAKE_CXX_STANDARD_REQUIRED": true,
    "CMAKE_CXX_EXTENSIONS": false
  }
},
{
  "name": "build", "inherits": "default",
  "cacheVariables": {
    "ffilesystem_BUILD_TESTING": false
  }
},
{ "name": "nostdfs", "inherits": "default",
  "displayName": "Build without std::filesystem",
  "description": "Build with C++ but without std::filesystem to test C fallback code.",
  "cacheVariables": {
    "ffilesystem_cpp": false
  }
},
{ "name": "nofortran", "inherits": "default",
  "displayName": "Build without Fortran",
  "description": "Build with C++ but without Fortran to test C fallback code.",
  "cacheVariables": {
    "ffilesystem_fortran": false
  }
},
{ "name": "isofortran", "inherits": "default",
  "displayName": "Use ISO_Fortran_binding.h",
  "description": "Build with ISO_Fortran_binding.h for Cpp-Fortran interfaces.",
  "cacheVariables": {
    "ffilesystem_iso_fortran_binding": true
  }
},
{
  "name": "cpp17", "inherits": "default",
  "displayName": "C++17",
  "description": "Build with C++17 standard enabled.",
  "cacheVariables": {
    "CMAKE_CXX_STANDARD": "17"
  }
},
{
  "name": "cpp23", "inherits": "default",
  "displayName": "C++23",
  "description": "Build with C++23 standard enabled.",
  "cacheVariables": {
    "CMAKE_CXX_STANDARD": "23"
  }
},
{
  "name": "cpp26", "inherits": "default",
  "displayName": "C++26",
  "description": "Build with C++26 standard enabled.",
  "cacheVariables": {
    "CMAKE_CXX_STANDARD": "26"
  }
},
{ "name": "debug", "inherits": "default",
  "cacheVariables": {
    "CMAKE_BUILD_TYPE": "Debug"
  }
},
{ "name": "msvc", "inherits": "nofortran",
  "displayName": "Visual Studio without Fortran",
  "generator": "Visual Studio 18 2026",
  "condition": {
    "type": "equals",
    "lhs": "${hostSystemName}",
    "rhs": "Windows"
  }
},
{ "name": "msvc-nostdfs", "inherits": "msvc",
  "displayName": "MSVC without std::filesystem",
  "description": "Build with MSVC but without std::filesystem to test C fallback code.",
  "cacheVariables": {
    "ffilesystem_cpp": false
  }
},
{
  "name": "linux", "inherits": "default",
  "displayName": "Linux build (for WSL on GHA)",
  "generator": "Ninja",
  "binaryDir": "/tmp/build",
  "installDir": "/tmp/build/local",
  "condition": {
    "type": "notEquals",
    "lhs": "${hostSystemName}",
    "rhs": "Windows"
  }
},
{ "name": "android", "inherits": "nofortran",
  "toolchainFile": "${sourceDir}/android.cmake",
  "binaryDir": "build-${presetName}",
  "cacheVariables": {
    "ffilesystem_BUILD_TESTING": false
  }
},
{ "name": "android-tests", "inherits": "android",
  "displayName": "Android NDK with tests",
  "description": "Cross-compile for Android and register tests.",
  "cacheVariables": {
    "ffilesystem_BUILD_TESTING": true,
    "CMAKE_CROSSCOMPILING_EMULATOR": "${sourceDir}/test/adb_run.sh"
  }
},
{ "name": "cosmo", "inherits": "nofortran",
  "displayName": "Cosmopolitan platform-independent framework",
  "toolchainFile": "${sourceDir}/cosmopolitan.cmake",
  "binaryDir": "build-${presetName}",
  "cacheVariables": {
    "ffilesystem_BUILD_TESTING": false
  }
},
{ "name": "ios", "inherits": "nofortran",
  "displayName": "iPhone",
  "toolchainFile": "${sourceDir}/ios.cmake",
  "binaryDir": "build-${presetName}",
  "cacheVariables": {
    "ffilesystem_extra": false,
    "ffilesystem_BUILD_TESTING": false,
    "CMAKE_OSX_SYSROOT": "iphoneos",
    "CMAKE_OSX_ARCHITECTURES": "arm64"
  },
  "condition": {
    "type": "equals",
    "lhs": "${hostSystemName}",
    "rhs": "Darwin"
  }
},
{ "name": "ios-sim", "inherits": "ios",
  "cacheVariables": {
    "CMAKE_OSX_SYSROOT": "iphonesimulator"
  }
},
{
  "name": "shared", "inherits": "default",
  "binaryDir": "build-shared",
  "installDir": "${fileDir}/build-shared/local",
  "displayName": "Shared Library",
  "description": "Build shared library instead of static.",
  "cacheVariables": {
    "BUILD_SHARED_LIBS": true,
    "ffilesystem_pic": true,
    "ffilesystem_ENABLE_RPATH": true
  }
},
{ "name": "shared-build", "inherits": ["shared", "build"], "displayName": "Build Shared Library",
  "cacheVariables": {
    "ffilesystem_BUILD_TESTING": false
  }
},
{ "name": "shared-nofortran", "inherits": ["shared", "nofortran"], "displayName": "Shared Library without Fortran" },
{ "name": "shared-nofortran-build", "inherits": ["shared-build", "nofortran"], "displayName": "Build Shared Library without Fortran" },
{ "name": "matlab", "inherits": "shared-build",
  "binaryDir": "build-matlab",
  "displayName": "Matlab",
  "cacheVariables": { "ffilesystem_BUILD_TESTING": false }
},
{ "name": "matlab-msvc", "inherits": ["msvc", "matlab"],
  "binaryDir": "build-matlab",
  "displayName": "Matlab with MSVC",
  "description": "Build with Matlab x64 support using MSVC. Update in the future if Matlab natively supports ARM64.",
  "architecture": "x64",
  "cacheVariables": { "ffilesystem_BUILD_TESTING": false }
},
{
  "name": "coverage",
  "binaryDir": "build-coverage",
  "displayName": "Code Coverage",
  "description": "Build with code coverage enabled.",
  "cacheVariables": {
    "CMAKE_BUILD_TYPE": "Debug",
    "ffilesystem_coverage": true,
    "ffilesystem_fallback": false
  }
},
{
  "name": "tidy", "inherits": "default",
  "displayName": "Clang-Tidy",
  "description": "Build with clang-tidy enabled.",
  "cacheVariables": {
    "CMAKE_BUILD_TYPE": "Debug",
    "ffilesystem_tidy": true
  }
}
],
"buildPresets": [
  { "name": "default", "configurePreset": "default" },
  { "name": "isofortran", "configurePreset": "isofortran" ,
    "description": "Build with ISO_Fortran_binding.h for Cpp-Fortran interfaces.",
    "targets": ["filesystem_cli", "test_realpath_fortran", "test_realpath_cfi_fortran"]
  },
  { "name": "build", "configurePreset": "build" },
  { "name": "nofortran", "configurePreset": "nofortran" },
  { "name": "linux", "configurePreset": "linux" },
  { "name" : "nostdfs", "configurePreset": "nostdfs" },
  { "name": "cpp17", "configurePreset": "cpp17" },
  { "name": "cpp23", "configurePreset": "cpp23" },
  { "name": "cpp26", "configurePreset": "cpp26" },
  { "name": "shared", "configurePreset": "shared" },
  { "name": "shared-build", "configurePreset": "shared-build" },
  { "name": "shared-nofortran", "configurePreset": "shared-nofortran" },
  { "name": "shared-nofortran-build", "configurePreset": "shared-nofortran-build" },
  { "name": "android", "configurePreset": "android" },
  { "name": "android-tests", "configurePreset": "android-tests"},
  { "name": "cosmo", "configurePreset": "cosmo" },
  { "name": "ios", "configurePreset": "ios" },
  { "name": "ios-sim", "configurePreset": "ios-sim" },
  { "name": "msvc", "configurePreset": "msvc", "configuration": "Release", "jobs": 8 },
  { "name": "msvc-nostdfs", "configurePreset": "msvc-nostdfs", "inherits": "msvc" },
  { "name": "matlab", "configurePreset": "matlab", "targets": ["ffilesystem", "fs_cli"] },
  { "name": "matlab-msvc", "configurePreset": "matlab-msvc", "inherits": ["matlab", "msvc"] },
  {
    "name": "explain",
    "configurePreset": "default",
    "nativeToolOptions": ["-d", "explain"]
  },
  {
    "name": "keep",
    "configurePreset": "default",
    "nativeToolOptions": ["-d", "keeprsp", "-d", "keepdepfile"]
  },
  {
    "name": "stats",
    "configurePreset": "default",
    "nativeToolOptions": ["-d", "stats"]
  },
  { "name": "debug", "inherits": "default", "configurePreset": "debug", "configuration": "Debug" },
  { "name": "tidy", "configurePreset": "tidy" },
  { "name": "coverage", "configurePreset": "coverage" },
  { "name": "run-coverage", "configurePreset": "coverage", "targets": "coverage" }
],
"testPresets": [
{
  "name": "default",
  "configurePreset": "default",
  "configuration": "Release",
  "description": "Don't use jobs=0 as this causes ulimit crashes due too many open files",
  "output": {
    "outputOnFailure": true,
    "verbosity": "verbose"
  },
  "execution": {
    "noTestsAction": "error",
    "scheduleRandom": true,
    "stopOnFailure": false,
    "jobs": 8
  }
},
{ "name": "shared", "configurePreset": "shared", "inherits": "default" },
{ "name": "shared-nofortran", "configurePreset": "shared-nofortran", "inherits": "default" },
{ "name": "isofortran", "configurePreset": "isofortran", "inherits": "default",
  "filter": {
    "include": {"name": "realpath"}
  }
},
{ "name": "nofortran", "configurePreset": "nofortran", "inherits": "default" },
{ "name": "linux", "configurePreset": "linux", "inherits": "default" },
{ "name": "nostdfs", "configurePreset": "nostdfs", "inherits": "default" },
{ "name": "cpp17", "configurePreset": "cpp17", "inherits": "default" },
{ "name": "cpp23", "configurePreset": "cpp23", "inherits": "default" },
{ "name": "cpp26", "configurePreset": "cpp26", "inherits": "default" },
{ "name": "android-tests", "configurePreset": "android-tests", "inherits": "default",
  "description": "adb push clashes with multiple tests using same executable, so do jobs=1",
  "execution": {
    "jobs": 1
  }
},
{ "name": "msvc", "configurePreset": "msvc", "inherits": "default" },
{ "name": "msvc-nostdfs", "configurePreset": "msvc-nostdfs", "inherits": "msvc" },
{
  "name": "debug", "inherits": "default",
  "configurePreset": "debug",
  "configuration": "Debug"
}
],
"workflowPresets": [
  { "name": "default",
    "displayName": "Build and test with C++20 standard",
    "steps": [
      { "type": "configure", "name": "default" },
      { "type": "build", "name": "default" },
      { "type": "test", "name": "default" }
    ]
  },
  { "name": "build",
    "steps": [
      { "type": "configure", "name": "build" },
      { "type": "build", "name": "build" }
    ]
  },
  { "name": "nofortran",
    "displayName": "Build & test without Fortran",
