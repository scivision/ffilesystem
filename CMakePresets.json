{
  "version": 6,

"configurePresets": [
{
  "name": "default",
  "generator": "Ninja",
  "binaryDir": "build",
  "installDir": "${fileDir}/build/local",
  "cacheVariables": {
    "ffilesystem_warning_as_error": true,
    "ffilesystem_fallback": false,
    "CMAKE_MESSAGE_LOG_LEVEL": "VERBOSE",
    "ffilesystem_BUILD_TESTING": true
  }
},
{"name": "build", "inherits": "default",
  "cacheVariables": {
    "ffilesystem_BUILD_TESTING": false
  }
},
{ "name": "debug", "inherits": "default",
  "cacheVariables": {
    "CMAKE_BUILD_TYPE": "Debug"
  }
},
{
  "name": "release", "inherits": "default",
  "cacheVariables": {
    "CMAKE_BUILD_TYPE": "Release"
  }
},
{ "name": "msvc", "inherits": "release", "generator": "Visual Studio 18 2026" },
{
  "name": "shared", "inherits": "default",
  "binaryDir": "build-shared",
  "installDir": "${fileDir}/build-shared/local",
  "displayName": "Shared Library",
  "description": "Build shared library instead of static.",
  "cacheVariables": {
    "BUILD_SHARED_LIBS": true,
    "ffilesystem_ENABLE_RPATH": true
  }
},
{
  "name": "coverage",
  "binaryDir": "build-coverage",
  "displayName": "Code Coverage",
  "description": "Build with code coverage enabled.",
  "cacheVariables": {
    "CMAKE_BUILD_TYPE": "Debug",
    "ffilesystem_coverage": true,
    "ffilesystem_fallback": false
  }
},
{
  "name": "tidy", "inherits": "default",
  "displayName": "Clang-Tidy",
  "description": "Build with clang-tidy enabled.",
  "cacheVariables": {
    "CMAKE_BUILD_TYPE": "Debug",
    "ffilesystem_tidy": true
  }
}
],
"buildPresets": [
  { "name": "default", "configurePreset": "default", "jobs": 0 },
  { "name": "build", "configurePreset": "build", "inherits": "default" },
  { "name": "shared", "configurePreset": "shared", "inherits": "default" },
  { "name": "msvc", "configurePreset": "msvc", "inherits": "release" },
  {
    "name": "explain",
    "configurePreset": "default",
    "nativeToolOptions": ["-d", "explain"]
  },
  {
    "name": "keep",
    "configurePreset": "default",
    "nativeToolOptions": ["-d", "keeprsp", "-d", "keepdepfile"]
  },
  {
    "name": "stats",
    "configurePreset": "default",
    "nativeToolOptions": ["-d", "stats"]
  },
  {
    "name": "release", "inherits": "default",
    "configurePreset": "release",
    "configuration": "Release"
  },
  {
    "name": "debug", "inherits": "default",
    "configurePreset": "debug",
    "configuration": "Debug"
  },
  {
    "name": "tidy",
    "configurePreset": "tidy"
  },
  {
    "name": "coverage",
    "configurePreset": "coverage"
  },
  {
    "name": "run-coverage",
    "configurePreset": "coverage",
    "targets": "coverage"
  }
],
"testPresets": [
{
  "name": "default",
  "configurePreset": "default",
  "output": {
    "outputOnFailure": true,
    "verbosity": "verbose"
  },
  "execution": {
    "noTestsAction": "error",
    "scheduleRandom": true,
    "stopOnFailure": false,
    "jobs": 8,
    "$comment": "don't put 0 or ulimit too many open files failures result"
  }
},
{ "name": "shared", "configurePreset": "shared", "inherits": "default" },
{
  "name": "release", "inherits": "default",
  "configurePreset": "release",
  "configuration": "Release"
},
{ "name": "msvc", "configurePreset": "msvc", "inherits": "release" },
{
  "name": "debug", "inherits": "default",
  "configurePreset": "debug",
  "configuration": "Debug"
}
],
"workflowPresets": [
  {
    "name": "default",
    "steps": [
      { "type": "configure", "name": "default" },
      { "type": "build", "name": "default" },
      { "type": "test", "name": "default" }
    ]
  },
  {
    "name": "build",
    "steps": [
      { "type": "configure", "name": "build" },
      { "type": "build", "name": "build" }
    ]
  },
  {
    "name": "shared",
    "steps": [
      { "type": "configure", "name": "shared" },
      { "type": "build", "name": "shared" },
      { "type": "test", "name": "shared" }
    ]
  },
  {
    "name": "debug",
    "steps": [
      { "type": "configure", "name": "debug" },
      { "type": "build", "name": "debug" },
      { "type": "test", "name": "debug"}
    ]
  },
  {
    "name": "release",
    "steps": [
      { "type": "configure", "name": "release" },
      { "type": "build", "name": "release" },
      { "type": "test", "name": "release" }
    ]
  },
    {
      "name": "msvc",
      "steps": [
        { "type": "configure", "name": "msvc" },
        { "type": "build", "name": "msvc" },
        { "type": "test", "name": "msvc" }
      ]
    },
  {
    "name": "tidy",
    "steps": [
      { "type": "configure", "name": "tidy" },
      { "type": "build", "name": "tidy" }
    ]
  }
]
}
